# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Publishable key — safe in browser when RLS is enabled
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Secret key — server-only, bypasses RLS; never expose to client
SUPABASE_SECRET_KEY=sb_secret_...

# --- JWT for rotating QR token ---
# Generate: openssl rand -base64 32
QR_JWT_SECRET=replace-with-32-byte-random-secret

# --- Auth allow-list ---
ALLOWED_EMAIL_DOMAIN=email.kmutnb.ac.th

# --- App config ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
